# Microsoft Graph (Vikram's Outlook business mailbox)
# Confidential client auth via certificate (tenant policy blocks client secrets).
# See workflows/outlook_setup.md for how to obtain these.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CERT_THUMBPRINT=
# Pick ONE of the following two — _PATH is convenient locally, _KEY (full PEM
# content) is what GitHub Actions uses via a Secret.
MS_CERT_PRIVATE_KEY_PATH=.secrets/concept-classifier.key
# MS_CERT_PRIVATE_KEY=
MS_REFRESH_TOKEN=

# Gemini 2.5 Flash — classifier
GEMINI_API_KEY=
